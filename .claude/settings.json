{
  "effortLevel": "high",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/claude/hooks/permission-save-tool.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "PANE=\"${TMUX_PANE#%}\"; NID=\"/tmp/claude-permissions/notif-id-${PANE}\"; [ -f \"$NID\" ] && dunstify -C \"$(cat \"$NID\")\" 2>/dev/null; rm -f \"/tmp/claude-permissions/$PANE\" \"/tmp/claude-permissions/tool-info-${PANE}.json\" \"$NID\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/claude/hooks/notification-hook.sh"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.config/claude/hooks/notification-hook.sh"
          }
        ]
      }
    ]
  }
}
