{
  "cleanupPeriodDays": 100,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "opus",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "p=$(jq -r '.prompt // \"\"'); name=$(echo \"$p\" | sed -nE 's|^/rename[[:space:]]+(.*[^[:space:]])[[:space:]]*$|\\1|p'); [ -n \"${TMUX:-}\" ] && [ -n \"$name\" ] && tmux rename-window \"$name\"; exit 0"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/martin/repos/qs-picker/scripts/claude-session-register"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/martin/repos/qs-picker/scripts/claude-session-register"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/martin/repos/qs-picker/scripts/claude-session-register"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/martin/repos/qs-picker/scripts/claude-session-register"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.scripts/claude-statusline"
  },
  "enabledPlugins": {
    "vercel@claude-plugins-official": true
  },
  "effortLevel": "high",
  "awaySummaryEnabled": false,
  "tui": "default",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "theme": "custom:dotfiles-dark",
  "preferredNotifChannel": "notifications_disabled",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true
}