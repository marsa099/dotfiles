{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "p=$(jq -r '.prompt // \"\"'); name=$(echo \"$p\" | sed -nE 's|^/rename[[:space:]]+(.*[^[:space:]])[[:space:]]*$|\\1|p'); [ -n \"${TMUX:-}\" ] && [ -n \"$name\" ] && tmux rename-window \"$name\"; exit 0"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.scripts/claude-statusline"
  },
  "enabledPlugins": {
    "vercel@claude-plugins-official": true
  },
  "effortLevel": "high",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "theme": "light-ansi",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "awaySummaryEnabled": false
}