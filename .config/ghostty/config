command = /usr/bin/bash
click-repeat-interval = 500
gtk-single-instance = false
auto-update-channel = tip
theme = light:light,dark:dark

# Padding between window edge and terminal content (ghostty-only, doesn't affect other windows)
window-padding-x = 8
window-padding-y = 8
keybind = ctrl+shift+j=scroll_page_down
keybind = ctrl+shift+k=scroll_page_up
keybind = ctrl+shift+x=write_scrollback_file:open,plain
