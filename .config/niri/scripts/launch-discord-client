#!/usr/bin/env bash
# Launch the native QML Discord client. The packaged dsqrd-client wrapper ensures
# the dsqrd daemon is running (it serves data + live gateway events), then opens
# the Quickshell UI pointed at dsqrd's socket. niri-jump-or-exec focuses an
# existing window instead of calling this when one is already open.
export PATH="/etc/profiles/per-user/$USER/bin:/run/current-system/sw/bin:$PATH"

# `U` in the UI applies an available update via this host-side command.
# Run in a terminal that stays open (--hold) so the outcome is always readable.
export SLK_UPDATE_CMD="kitty --hold -e $HOME/.scripts/update-dsqrd"

# Reap windowless dsqrd UI orphans before launching. A failed config load leaves
# quickshell alive without mapping a window; niri-jump-or-exec then can't focus
# it, so each launch piled up another. Scoped to dsqrd by its store UI path.
WIN_PIDS=" $(niri msg --json windows 2>/dev/null | python3 -c 'import json,sys;[print(w.get("pid")) for w in json.load(sys.stdin)]' 2>/dev/null | tr "\n" " ") "
for p in /proc/[0-9]*; do
    exe=$(readlink "$p/exe" 2>/dev/null) || continue
    case "$exe" in *quickshell*) ;; *) continue ;; esac
    case "$(tr '\0' ' ' < "$p/cmdline" 2>/dev/null)" in *share/dsqrd/ui*) ;; *) continue ;; esac
    pid=${p#/proc/}
    case "$WIN_PIDS" in *" $pid "*) ;; *) kill "$pid" 2>/dev/null ;; esac
done

exec dsqrd-client
