{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    // "width": 1280, // Waybar width
    // Choose the order of the modules
    "reload_style_on_change": true,
    "margin-top": 0,
    "margin-bottom": 0,
    "modules-left": ["group/hardware", "custom/idp-status", "custom/devops"],
    "modules-center": ["custom/claude-focused", "custom/helium-focused", "custom/dnd"],
    "modules-right": ["custom/claude-cost", "custom/claude-pending", "tray", "group/system"],
    "niri/workspaces": {
         "disable-scroll": true,
         "sort-by-name": true,
         "format": "{icon}",
         "format-icons": {
             "main": "юо┤",
             "chat": "юо┤",
             "default": "юо┤",
         },
     },
    "tray": {
        "icon-size": 16,
        "spacing": 16
    },
    "custom/music": {
        "format": "яАБ  {}",
        "escape": true,
        "interval": 5,
        "tooltip": false,
        "exec": "playerctl metadata --format='{{ artist }} - {{ title }}'",
        "on-click": "playerctl play-pause",
        "max-length": 50
    },
    "clock": {
        "timezone": "Europe/Stockholm",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "ґ░Гн  {:%d %b  %H:%M:%S}",
        "format": "{:%H:%M}",
        "interval": 1
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"]
    },
    "battery": {
        "states": {
            "critical": 10
        },
        "format": "{icon}",
        "format-charging": "ґ░ВД",
        "format-plugged": "ґ░Ъе",
        "tooltip-format": "{capacity}% тАФ {time}",
        "format-icons": [
          "\uf244",
          "\uf243",
          "\uf242",
          "\uf241",
          "\uf240"
        ]
    },
    "pulseaudio#speaker": {
        "format": "",
        "format-muted": "ґ░ЦБ",
        "on-click": "pavucontrol",
        "tooltip": false
    },
    "pulseaudio#mic": {
        "format": "{format_source}",
        "format-muted": "{format_source}",
        "format-source": "",
        "format-source-muted": "ґ░Нн",
        "on-click": "pavucontrol",
        "tooltip": false
    },
    "network": {
        "format-wifi": "{icon}",
        "format-ethernet": "ґ░ИБ",
        "tooltip-format": "{essid} ({signalStrength}%)\n{ifname} via {gwaddr}",
        "format-linked": " {ifname} (No IP)",
        "format-disconnected": "ґ░до",
        "format-alt": "{ipaddr}/{cidr}",
        "format-icons": {
            "wifi": ["\uf1eb"],
            "ethernet": "",
            "disconnected": "ґ░до"
        },
        "interval": 5
    },
   "bluetooth": {
        "format": "ґ░Вп",
        "format-on": "ґ░В▒",
        "format-off": "ґ░Вп",
        "format-disabled": "ґ░В▓",
        "format-connected": "ґ░В░",
        "format-connected-battery": "ґ░В░  {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\t{controller_address} ({status})\n\n{num_connections} connected",
        "tooltip-format-off": "{controller_alias}\t{controller_address} (off)",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\tґ░еЙ {device_battery_percentage}%",
        "on-click": "blueman-manager"
   },
   "cpu": {
        "interval": 5,
        "format": "ґ░НЫ  {usage}%",
        "format-alt": "CPU: {avg_frequency}GHz | {load}",
        "tooltip": true,
        "states": {
            "low": 20,
            "medium": 50,
            "elevated": 70,
            "critical": 85
        }
   },
   "memory": {
        "interval": 5,
        "format": "ґ░ШЪ  {percentage}%",
        "format-alt": "MEM: {used:0.1f}GB/{total:0.1f}GB",
        "tooltip-format": "Used: {used:0.1f}GB\nAvailable: {avail:0.1f}GB\nTotal: {total:0.1f}GB",
        "states": {
            "low": 20,
            "medium": 50,
            "elevated": 70,
            "critical": 85
        }
   },
   "group/audio": {
        "orientation": "inherit",
        "modules": ["pulseaudio#mic", "pulseaudio#speaker"]
   },
   "custom/language": {
        "exec": "~/.local/bin/waybar-language",
        "interval": 1,
        "tooltip": false
   },
   "group/system": {
        "orientation": "inherit",
        "modules": ["custom/language", "bluetooth", "network", "battery", "clock"]
   },
   "custom/screencast": {
        "exec": "~/.local/bin/waybar-screencast",
        "return-type": "json",
        "interval": 1,
        "tooltip": true
   },
   "custom/camera": {
        "exec": "~/.local/bin/waybar-camera",
        "return-type": "json",
        "interval": 1,
        "tooltip": true
   },
   "custom/dnd": {
        "exec": "~/.scripts/waybar-dnd",
        "return-type": "json",
        "interval": "once",
        "signal": 10,
        "tooltip": true,
        "on-click": "~/.scripts/waybar-dnd-toggle"
   },
   "group/hardware": {
        "orientation": "inherit",
        "modules": ["cpu", "memory", "custom/cpu-temp", "custom/gpu-temp", "custom/screencast", "custom/camera", "pulseaudio#mic"]
   },
   "custom/idp-status": {
        "exec": "~/.scripts/waybar-idp-status",
        "return-type": "json",
        "interval": 30,
        "tooltip": true,
        "markup": "pango",
        "format": "{}"
   },
   "custom/devops": {
        "exec": "~/.scripts/waybar-devops/waybar-devops",
        "return-type": "json",
        "interval": 1,
        "tooltip": true,
        "format": "{}",
        "markup": "pango"
   },
   "custom/claude-focused": {
        "exec": "~/.scripts/waybar-claude-focused",
        "return-type": "json",
        "restart-interval": 3,
        "format": "{}",
        "tooltip": true,
        "on-click": "quickshell -p /home/martin/repos/qs-picker/shell.qml ipc call claude-picker toggle"
   },
   "custom/helium-focused": {
        "exec": "~/.scripts/waybar-helium-focused",
        "return-type": "json",
        "restart-interval": 3,
        "format": "{}",
        "tooltip": true,
        "on-click": "qs -p /home/martin/repos/qs-picker/shell.qml ipc call helium-picker toggle"
   },
   "custom/claude-cost": {
        "exec": "~/.scripts/waybar-claude-cost",
        "return-type": "json",
        "restart-interval": 5,
        "format": "{}",
        "tooltip": true,
        "on-click": "~/.scripts/waybar-claude-cost --toggle"
   },
   "custom/claude-pending": {
        "exec": "~/.scripts/waybar-claude-pending",
        "return-type": "json",
        "interval": 2,
        "format": "{}",
        "tooltip": true,
        "on-click": "claude-notify-goto",
        "on-click-right": "claude-notify-navigate"
   },
   "custom/cpu-temp": {
        "exec": "sensors k10temp-pci-00c3 | awk '/Tccd1:/ {gsub(/[^0-9.]/, \"\", $2); printf \"%.0f\", $2}'",
        "format": "ґ░ФП  {}┬░/",
        "interval": 5,
        "tooltip-format": "CPU Temperature (Tccd1)"
   },
   "custom/gpu-temp": {
        "exec": "nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader,nounits",
        "format": "{}┬░",
        "interval": 5,
        "tooltip-format": "GPU Temperature (RTX 5080)"
   }
}
