.config/gh

# Systemd symlinks (created by systemctl enable)
.config/systemd/user/*.target.wants/

# Build artifacts and dependencies
node_modules/
dist/
*.js.map

# Cache directories
.cache/
Cache/

# Editor files
.vscode/
*.swp
*.swo

# Machine-specific
.env
.local/share/

# tmux plugins (managed by TPM)
.config/tmux/plugins/

# Backup files
*.backup
*.bak
*~

# Generated by themes-generator (~/repos/themes-generator is canonical source)
.config/dunst/dunstrc
.config/ghostty/themes/dark
.config/ghostty/themes/light
.config/gtk-3.0/gtk.css
.config/gtk-4.0/gtk.css
.config/kitty/theme.conf
.config/nvim/colors/custom-theme-dark.lua
.config/nvim/colors/custom-theme-light.lua
.config/tmux/theme.conf
.config/waybar/style.css
.config/gtk-3.0/settings.ini
.config/theme_mode
