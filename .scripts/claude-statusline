#!/usr/bin/env bash
set -euo pipefail

input=$(cat)

dim=$'\033[2m'
rst=$'\033[0m'
sep="${dim} · ${rst}"

# Color a percentage by severity. Tier thresholds are configurable per call.
# Defaults: green < 50 < yellow < 75 < orange < 90 < red.
pct_color() {
    local p="$1" t1="${2:-50}" t2="${3:-75}" t3="${4:-90}"
    awk -v p="$p" -v t1="$t1" -v t2="$t2" -v t3="$t3" 'BEGIN{
        if (p < t1)      printf "\033[32m"
        else if (p < t2) printf "\033[38;5;208m"
        else if (p < t3) printf "\033[33m"
        else             printf "\033[1;31m"
    }'
}

model=$(jq -r '.model.display_name // empty' <<<"$input")
dir=$(jq -r '.workspace.current_dir // empty' <<<"$input" | sed "s|$HOME|~|")

ctx_used_pct=$(jq -r '.context_window.used_percentage // empty' <<<"$input")
ctx_total=$(jq -r '.context_window.context_window_size // empty' <<<"$input")
ctx_cur=$(jq -r '
  [ .context_window.current_usage.input_tokens
  , .context_window.current_usage.cache_creation_input_tokens
  , .context_window.current_usage.cache_read_input_tokens
  ] | map(. // 0) | add
' <<<"$input")

rl_5h=$(jq -r '.rate_limits.five_hour.used_percentage // empty' <<<"$input")
rl_7d=$(jq -r '.rate_limits.seven_day.used_percentage // empty' <<<"$input")
rl_7d_resets=$(jq -r '.rate_limits.seven_day.resets_at // empty' <<<"$input")

parts=()
[ -n "$model" ] && parts+=("$model")
[ -n "$dir" ] && parts+=("${dim}${dir}${rst}")

if [ -n "$ctx_cur" ] && [ "$ctx_cur" != "0" ] && [ -n "$ctx_total" ]; then
    k=$(awk -v c="$ctx_cur" 'BEGIN{ printf "%.1fk", c/1000 }')
    tk=$(awk -v t="$ctx_total" 'BEGIN{ printf "%.0fk", t/1000 }')
    if [ -n "$ctx_used_pct" ]; then
        col=$(pct_color "$ctx_used_pct" 20 30 90)
        ctx="${col}${k}${rst}${dim}/${tk}${rst} ${dim}(${rst}${col}$(printf '%.0f' "$ctx_used_pct")%${rst}${dim})${rst}"
    else
        ctx="${k}${dim}/${tk}${rst}"
    fi
    parts+=("$ctx")
fi

if [ -n "$rl_5h" ]; then
    col=$(pct_color "$rl_5h")
    parts+=("${dim}5h${rst} ${col}$(printf '%.0f' "$rl_5h")%${rst}")
fi
if [ -n "$rl_7d" ]; then
    col=$(pct_color "$rl_7d")
    wk="${dim}wk${rst} ${col}$(printf '%.0f' "$rl_7d")%${rst}"
    if [ -n "$rl_7d_resets" ]; then
        left=$(awk -v r="$rl_7d_resets" -v n="$(date +%s)" 'BEGIN{
            s = r - n
            if (s <= 0) exit
            if (s < 86400) printf "%dh", (s + 1800) / 3600
            else           printf "%dd", (s + 43200) / 86400
        }')
        [ -n "$left" ] && wk+=" ${dim}(${left})${rst}"
    fi
    parts+=("$wk")
fi

out=""
for i in "${!parts[@]}"; do
    [ "$i" -gt 0 ] && out+="$sep"
    out+="${parts[$i]}"
done
printf '%s' "$out"
