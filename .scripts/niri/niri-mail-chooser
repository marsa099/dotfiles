#!/usr/bin/env bash
# Usage: niri-mail-chooser focus|choose
#   focus  — focus/cycle existing mail windows; if none, open chooser
#   choose — always open the rofi chooser
# While the chooser is open, re-invoking the script (e.g. by tapping
# Super+M / Super+Shift+M again) advances the highlight by injecting a
# synthetic Down key via wtype. Enter accepts, Esc cancels. "Release Super
# to confirm" isn't achievable on wayland (niri has no key-release events,
# rofi has no idle-timeout).

set -u

MODE="${1:-focus}"

# Each entry: label|app_id|spawn_command|icon_path
# TODO: replace the Regent entry with the real profile/URL when known.
MAILS=(
    "SIS|chrome-outlook.office365.com__mail-Profile_3|google-chrome-stable --profile-directory=\"Profile 3\" --app=\"https://outlook.office365.com/mail\"|$HOME/.config/rofi/icons/sis-mark.svg"
    "Regent|chrome-outlook.office365.com__mail-Default|google-chrome-stable --profile-directory=\"Default\" --app=\"https://outlook.office365.com/mail\"|$HOME/.config/rofi/icons/regent-mark.png"
)

SPAWN_OR_FOCUS="$HOME/.scripts/niri/niri-spawn-or-focus"
ROFI_THEME="$HOME/.config/rofi/theme.rasi"
ICON_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/niri-mail-chooser"
ACCENT="#FF570D"

# If a rofi popup is already open, any re-invocation just cycles the
# selection: send a Down arrow to whatever has keyboard focus (rofi, since
# it has the exclusive grab). This is needed because niri's Mod+M binding
# fires before rofi gets the key — so the keypress reaches THIS script
# rather than rofi's internal kb-row-down.
if pgrep -x rofi >/dev/null 2>&1; then
    wtype -k Down
    exit 0
fi

# Render a composite PNG (64x80): the 64x64 icon centered inside a 64x80
# transparent canvas via -extent, which gives 8px top + 8px bottom margin and
# keeps the icon visually centered inside the rofi element. For "open" mail
# accounts an orange dot is drawn near the bottom edge of the canvas.
# Result is cached in ICON_CACHE; only rebuilt if base icon is newer.
COMPOSITE_VERSION=v3
make_composite() {
    local base="$1" open="$2" out="$3"
    mkdir -p "$ICON_CACHE"
    if [ -f "$out" ] && [ "$out" -nt "$base" ]; then
        return 0
    fi
    if [ "$open" = "true" ]; then
        nix run nixpkgs#imagemagick -- \
            "$base" -background none -density 300 -resize 64x64 \
            -gravity center -extent 64x80 \
            -fill "$ACCENT" -draw "circle 32,76 32,73" \
            "$out"
    else
        nix run nixpkgs#imagemagick -- \
            "$base" -background none -density 300 -resize 64x64 \
            -gravity center -extent 64x80 \
            "$out"
    fi
}

act_on_choice() {
    local choice="$1" m label rest app_id cmd
    [ -z "$choice" ] && return
    for m in "${MAILS[@]}"; do
        label="${m%%|*}"
        if [ "$label" = "$choice" ]; then
            rest="${m#*|}"
            app_id="${rest%%|*}"
            rest="${rest#*|}"
            cmd="${rest%|*}"
            "$SPAWN_OR_FOCUS" "$app_id" "$cmd"
            return
        fi
    done
}

show_chooser() {
    # Horizontal pair of logo tiles. The "open" indicator (orange dot) is baked
    # into the icon image itself via make_composite — that puts the dot fully
    # outside the rofi element border, since rofi just sees one taller image.
    local theme_overrides='
        window {
            width: 220px;
            padding: 16px;
            border-radius: 12px;
            background-color: #D8D8D8;
        }
        mainbox { spacing: 0; children: ["listview"]; }
        listview {
            lines: 1;
            columns: 2;
            fixed-height: true;
            spacing: 8px;
        }
        element {
            padding: 6px;
            border-radius: 6px;
            spacing: 0;
            orientation: vertical;
            children: ["element-icon"];
            horizontal-align: 0.5;
            vertical-align: 0.5;
            border: 0;
        }
        element selected.normal {
            background-color: rgba(0, 0, 0, 0.18);
            border: 0;
        }
        element-icon {
            size: 80px;
            horizontal-align: 0.5;
            vertical-align: 0.5;
            expand: false;
        }
    '

    # Snapshot which configured mail app_ids currently have a window open
    local open_ids
    open_ids=$(niri msg -j windows | jq -r '.[].app_id')

    local choice
    choice=$(
        for m in "${MAILS[@]}"; do
            local label="${m%%|*}"
            local rest="${m#*|}"
            local app_id="${rest%%|*}"
            local base_icon="${m##*|}"
            local open="false"
            if grep -qxF "$app_id" <<< "$open_ids"; then
                open="true"
            fi
            local cache_key
            cache_key=$(printf '%s|%s|%s' "$base_icon" "$open" "$COMPOSITE_VERSION" | sha1sum | cut -c1-16)
            local composite="$ICON_CACHE/$cache_key.png"
            make_composite "$base_icon" "$open" "$composite" >&2
            printf '%s\0icon\x1f%s\n' "$label" "$composite"
        done | rofi -dmenu \
            -theme "$ROFI_THEME" \
            -theme-str "$theme_overrides" \
            -show-icons \
            -kb-row-down "Down" \
            -kb-row-up "Up" \
            -no-custom
    )
    act_on_choice "$choice"
}

if [ "$MODE" = "choose" ]; then
    show_chooser
    exit 0
fi

# focus mode: look for any windows matching the configured mail app_ids
ID_SELECT=""
for m in "${MAILS[@]}"; do
    rest="${m#*|}"
    aid="${rest%%|*}"
    [ -n "$ID_SELECT" ] && ID_SELECT="$ID_SELECT or "
    ID_SELECT="${ID_SELECT}.app_id == \"$aid\""
done

WINDOWS=$(niri msg -j windows | jq "[.[] | select($ID_SELECT)] | sort_by(.id)")
COUNT=$(echo "$WINDOWS" | jq 'length')

if [ "$COUNT" -eq 0 ]; then
    show_chooser
    exit 0
fi

FOCUSED_ID=$(echo "$WINDOWS" | jq -r '.[] | select(.is_focused) | .id // empty' | head -1)

if [ -n "$FOCUSED_ID" ]; then
    mapfile -t WINDOW_IDS < <(echo "$WINDOWS" | jq -r '.[].id')
    CURRENT_IDX=0
    for i in "${!WINDOW_IDS[@]}"; do
        if [ "${WINDOW_IDS[$i]}" = "$FOCUSED_ID" ]; then
            CURRENT_IDX=$i
            break
        fi
    done
    NEXT_IDX=$(( (CURRENT_IDX + 1) % COUNT ))
    niri msg action focus-window --id "${WINDOW_IDS[$NEXT_IDX]}"
else
    FIRST_ID=$(echo "$WINDOWS" | jq -r '.[0].id')
    niri msg action focus-window --id "$FIRST_ID"
fi
