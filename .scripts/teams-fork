#!/usr/bin/env bash
# Manages the Teams fork integration with NixOS.
#   teams-fork on        → use fork (default; flag file removed)
#   teams-fork off       → use stock teams-for-linux from nixpkgs
#   teams-fork deploy    → push fork → bump flake lock → nixos-rebuild
#   teams-fork           → print current target and pinned commit

set -euo pipefail

FLAG="${XDG_CONFIG_HOME:-$HOME/.config}/teams-launcher/use-stock"
FORK_REPO="$HOME/repos/teams-for-linux"
NIXOS="$HOME/.config/nixos"

case "${1:-status}" in
    on|fork)
        rm -f "$FLAG"
        echo "Super+T → fork"
        ;;
    off|stock)
        mkdir -p "$(dirname "$FLAG")"
        touch "$FLAG"
        echo "Super+T → stock"
        ;;
    deploy)
        cd "$FORK_REPO"
        if ! git diff-index --quiet HEAD --; then
            echo "fork repo has uncommitted changes — commit or stash first" >&2
            exit 1
        fi
        if [ "$(git rev-parse --abbrev-ref HEAD)" != "main" ]; then
            echo "fork repo is not on main — checkout main and merge first" >&2
            exit 1
        fi
        echo "→ pushing fork main..."
        git push origin main
        echo "→ bumping flake input..."
        cd "$NIXOS"
        nix flake lock --update-input teams-for-linux-fork
        echo "→ rebuilding system..."
        sudo nixos-rebuild switch --flake "$NIXOS#nixos"
        ;;
    status)
        if [ -f "$FLAG" ]; then
            echo "target: stock"
        else
            echo "target: fork"
        fi
        if [ -d "$NIXOS" ]; then
            cd "$NIXOS"
            pinned=$(nix flake metadata --json 2>/dev/null \
                | jq -r '.locks.nodes."teams-for-linux-fork".locked.rev // empty' 2>/dev/null \
                || true)
            if [ -n "$pinned" ]; then
                echo "pinned: ${pinned:0:7}"
            fi
            if [ -d "$FORK_REPO" ]; then
                head=$(cd "$FORK_REPO" && git rev-parse main 2>/dev/null || true)
                if [ -n "$head" ] && [ "$head" != "$pinned" ]; then
                    echo "fork main is at ${head:0:7} — run 'teams-fork deploy' to update"
                fi
            fi
        fi
        ;;
    *)
        echo "Usage: teams-fork [on|off|deploy|status]" >&2
        exit 1
        ;;
esac
