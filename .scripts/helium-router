#!/usr/bin/env bash
# Default browser + $BROWSER handler: route each opened URL to the Helium profile
# whose rule matches (qs-picker data/profile-rules.txt, via `bookmarks route`),
# falling back to the Private profile for anything unmatched. With no URL, opens
# Private. Replaces helium-private as the system link handler so links from Teams,
# Slack, the CLI, etc. land in the "right" profile instead of always Private.
BOOKMARKS="$HOME/repos/qs-picker/scripts/bookmarks"

focus_profile() {
    local dir="$1" id pid cmd

    command -v niri >/dev/null && command -v jq >/dev/null || return 0
    # A warm Chromium handoff adds the tab to an existing window without asking
    # niri to cross workspaces. Match the window by its browser process rather
    # than focusing whichever Helium profile happened to be used most recently.
    for _ in $(seq 40); do
        while IFS=$'\t' read -r id pid; do
            [ -r "/proc/$pid/cmdline" ] || continue
            cmd=$(tr '\0' ' ' <"/proc/$pid/cmdline")
            case "$cmd" in
                *"--user-data-dir=$HOME/.config/helium-$dir"*)
                    niri msg action focus-window --id "$id" >/dev/null 2>&1
                    return 0
                    ;;
            esac
        done < <(niri msg --json windows 2>/dev/null | jq -r '.[] | select(.pid != null) | [.id, .pid] | @tsv')
        sleep 0.15
    done
}

launch() {
    local url="$1" dir="Private" port=9226 out
    if [ -n "$url" ]; then
        out=$("$BOOKMARKS" route "$url" 2>/dev/null)
        [ -n "$out" ] && read -r dir port <<<"$out"
    fi
    # Launch detached and return immediately. When invoked as $BROWSER (e.g. by
    # `az login`), the caller waits for this command to exit before serving its
    # localhost OAuth callback; if we blocked (a fresh Helium foregrounds as the
    # browser and never returns) that callback would hang forever.
    setsid helium --user-data-dir="$HOME/.config/helium-$dir" \
           --profile-directory="$dir" \
           --remote-debugging-port="$port" ${url:+"$url"} \
           </dev/null >/dev/null 2>&1 &
    focus_profile "$dir" </dev/null >/dev/null 2>&1 &
}

if [ "$#" -eq 0 ]; then
    launch ""
else
    for u in "$@"; do launch "$u"; done
fi
