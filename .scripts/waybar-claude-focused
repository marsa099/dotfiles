#!/usr/bin/env python3
"""Waybar module: the Claude Code session you're currently focused in, live.

Reads niri's event stream and, whenever the focused window (or its title)
changes, maps the focused terminal window to a running Claude session and emits
a waybar JSON line. Live sessions come from ~/.claude/sessions/<pid>.json when
Claude writes it; newer builds (agent-teams / Remote Control) leave that empty,
so sessions are also discovered from /proc (a claude process carries
CLAUDE_CODE_SESSION_ID, its resume name in --name, and Remote Control via
CLAUDE_CODE_BRIDGE_SESSION_ID). The session's custom name is preferred;
otherwise the terminal title (sans status glyph).
Empty text when the focused window isn't a Claude session, so the module hides.

Event-driven, so the label flips the instant you switch windows — no polling.
`class` carries busy/idle + remote so the bar can colour it. Click opens the
session picker (wired in the waybar config).
"""
import json
import os
import re
import select
import subprocess
import sys

REGISTRY = os.path.expanduser("~/.claude/sessions")
TERMINALS = {"kitty", "foot", "alacritty", "wezterm-gui", "ghostty"}
ICON = "󰚩"


def emit(obj):
    sys.stdout.write(json.dumps(obj, ensure_ascii=False) + "\n")
    sys.stdout.flush()


def proc_field(pid, name):
    try:
        with open(f"/proc/{pid}/stat") as fh:
            data = fh.read()
    except OSError:
        return None
    rparen = data.rfind(")")
    fields = data[rparen + 2:].split()
    return fields  # caller indexes; field 4 (PPid) == index 1, field 22 == 19


def ppid_of(pid):
    f = proc_field(pid, "ppid")
    try:
        return int(f[1]) if f else None
    except (ValueError, IndexError):
        return None


def starttime_of(pid):
    f = proc_field(pid, "start")
    try:
        return f[19] if f else None
    except IndexError:
        return None


def ancestors(pid, limit=25):
    chain, cur, n = set(), pid, 0
    while cur and cur > 1 and n < limit:
        chain.add(cur)
        cur = ppid_of(cur)
        n += 1
    return chain


def _read_environ(pid):
    try:
        with open(f"/proc/{pid}/environ", "rb") as fh:
            raw = fh.read()
    except OSError:
        return {}
    env = {}
    for part in raw.split(b"\0"):
        if b"=" in part:
            k, _, v = part.partition(b"=")
            env[k.decode("utf-8", "replace")] = v.decode("utf-8", "replace")
    return env


def _cmdline_name(pid):
    """The `--name <x>` a claude process was launched with, or None."""
    try:
        with open(f"/proc/{pid}/cmdline", "rb") as fh:
            args = [a.decode("utf-8", "replace") for a in fh.read().split(b"\0") if a]
    except OSError:
        return None
    for i, a in enumerate(args):
        if a == "--name" and i + 1 < len(args):
            return args[i + 1]
    return None


def scan_proc_registry():
    """Live claude sessions discovered from /proc — the source once newer builds
    (agent-teams / Remote Control) stopped writing ~/.claude/sessions/<pid>.json.
    Matching here is by process ancestry (see label_for), so only pid/name/remote
    are needed; busy/idle status isn't exposed outside Claude's runtime (None)."""
    candidates = {}  # pid -> env
    try:
        entries = os.listdir("/proc")
    except OSError:
        return []
    for entry in entries:
        if not entry.isdigit():
            continue
        pid = int(entry)
        try:
            with open(f"/proc/{pid}/comm") as fh:
                comm = fh.read().strip()
        except OSError:
            continue
        if "claude" not in comm and comm != "node":
            continue
        env = _read_environ(pid)
        if env.get("CLAUDE_CODE_SESSION_ID"):
            candidates[pid] = env
    out = []
    for pid, env in candidates.items():
        # Skip a child claude/node subprocess; keep the top-level session process.
        if ppid_of(pid) in candidates:
            continue
        out.append({
            "pid": pid,
            "name": _cmdline_name(pid),
            "status": None,
            "remote": env.get("CLAUDE_CODE_BRIDGE_SESSION_ID") is not None,
        })
    return out


def load_registry():
    """Live sessions (list of dicts with pid/name/status/remote). Unions the
    procStart-verified ~/.claude/sessions registry (older builds) with /proc
    discovery (newer builds, where that registry is empty)."""
    out = []
    seen_pids = set()
    try:
        files = os.listdir(REGISTRY)
    except OSError:
        files = []
    for fn in files:
        if not fn.endswith(".json"):
            continue
        try:
            with open(os.path.join(REGISTRY, fn)) as fh:
                r = json.load(fh)
        except (OSError, ValueError):
            continue
        pid = r.get("pid")
        if not pid or starttime_of(pid) != str(r.get("procStart")):
            continue
        out.append({
            "pid": pid,
            "name": r.get("name"),
            "status": r.get("status"),
            "remote": r.get("bridgeSessionId") is not None,
        })
        seen_pids.add(pid)
    for s in scan_proc_registry():
        if s["pid"] not in seen_pids:
            out.append(s)
            seen_pids.add(s["pid"])
    return out


def strip_glyph(title):
    return re.sub(r"^[^\w]+", "", title or "").strip()


def label_for(window):
    """Return (text, klass) for the focused window, or ('', '') if not Claude."""
    if not window:
        return "", ""
    if window.get("app_id") not in TERMINALS:
        return "", ""
    wpid = window.get("pid")
    if not wpid:
        return "", ""
    for s in load_registry():
        if wpid in ancestors(s["pid"]):
            name = s.get("name")
            text = name if name else strip_glyph(window.get("title"))
            klass = (s.get("status") or "idle")
            if s.get("remote"):
                klass += " remote"
            return text, klass
    return "", ""


def main():
    try:
        proc = subprocess.Popen(
            ["niri", "msg", "--json", "event-stream"],
            stdout=subprocess.PIPE, text=True, bufsize=1,
        )
    except OSError:
        emit({"text": ""})
        return

    windows = {}        # id -> window dict
    focused_id = None
    last = None
    pending = 0         # remaining retries to resolve a just-focused terminal

    def refresh(arm):
        nonlocal last, pending
        win = windows.get(focused_id)
        text, klass = label_for(win)
        if text:
            pending = 0
        elif arm and win and win.get("app_id") in TERMINALS:
            # Terminal focused but no Claude session matched — likely just
            # spawned and its ~/.claude/sessions registry file isn't written
            # yet. Poll a few times (no niri event will fire when it appears).
            pending = 10
        out = {"text": (ICON + "  " + text) if text else "",
               "tooltip": "Focused Claude session: " + text if text else "",
               "class": klass}
        if out != last:
            last = out
            emit(out)

    def handle(ev):
        nonlocal windows, focused_id
        kind = next(iter(ev), None)
        body = ev.get(kind) or {}
        if kind == "WindowsChanged":
            windows = {w["id"]: w for w in body.get("windows", [])}
            focused_id = next((w["id"] for w in windows.values()
                               if w.get("is_focused")), focused_id)
            refresh(True)
        elif kind == "WindowOpenedOrChanged":
            w = body.get("window") or {}
            if w.get("id") is not None:
                windows[w["id"]] = w
                if w.get("is_focused"):
                    focused_id = w["id"]
                if w.get("id") == focused_id:
                    refresh(True)
        elif kind == "WindowClosed":
            wid = body.get("id")
            windows.pop(wid, None)
            if wid == focused_id:
                focused_id = None
                refresh(True)
        elif kind == "WindowFocusChanged":
            focused_id = body.get("id")
            refresh(True)

    # Read the raw fd ourselves and split lines manually. select() watches the
    # OS-level fd, so it MUST be the sole reader — mixing it with the buffered
    # proc.stdout.readline() loses events: niri batches several events into one
    # read, readline() returns one and parks the rest in Python's buffer, then
    # select() blocks because the OS fd is already drained. The stuck events
    # (incl. the focus change that should update the label) wait for the next
    # event, so the label lags. os.read on a ready fd never has that buffer.
    fd = proc.stdout.fileno()
    buf = ""
    while True:
        timeout = 0.4 if pending > 0 else None
        try:
            ready, _, _ = select.select([fd], [], [], timeout)
        except OSError:
            break
        if ready:
            try:
                chunk = os.read(fd, 65536)
            except OSError:
                break
            if not chunk:
                break
            buf += chunk.decode("utf-8", "replace")
            while "\n" in buf:
                line, buf = buf.split("\n", 1)
                if not line:
                    continue
                try:
                    handle(json.loads(line))
                except ValueError:
                    continue
        else:
            pending -= 1          # timeout tick: re-attempt resolving
            refresh(False)


if __name__ == "__main__":
    main()
