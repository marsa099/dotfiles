#!/usr/bin/env bash
# waybar-devops - Waybar module showing Azure DevOps build & deployment status
#
# Detects the focused terminal's working directory (tmux or bare terminal via
# niri IPC), checks if it's inside a git repo with an Azure DevOps remote, and
# shows either active build progress or the latest deployments per environment.
#
# Build lifecycle: tracks builds from start through completion, optional release
# deployment, and result display - persisting state even when focus changes.
#
# Priority: lifecycle state > active builds > deployed versions
# Build:   "Building (3/6: Test) - 1m 23s" with stage breakdown tooltip
# Deploy:  "T: test  P: 1.10.0" with env/branch tooltip
#
# Auth: PAT from system keyring via secret-tool (service=azure-devops, type=waybar).
# Cache: ~/.cache/waybar-devops/ (discovery 1h, deployments 60s, builds 10s)
# Log:   ~/.cache/waybar-devops/waybar-devops.log

# Exclude specific release definition IDs per repo (def IDs are per-project)
declare -A EXCLUDE_DEFS
EXCLUDE_DEFS["SIS.CommitteePortal"]="11"

CACHE_DIR="$HOME/.cache/waybar-devops"
STATE_FILE="$CACHE_DIR/state.json"
LIFECYCLE_FILE="$CACHE_DIR/build_lifecycle.json"
LOG_FILE="$CACHE_DIR/waybar-devops.log"
DEPLOY_TTL=60
DISCOVERY_TTL=3600
BUILD_TTL=10
STALE_TIMEOUT=10
PERSIST_TIMEOUT=60
MERGE_CHECK_TTL=300
LOG_MAX_LINES=500

mkdir -p "$CACHE_DIR"

log() {
    echo "$(date '+%H:%M:%S') $*" >> "$LOG_FILE"
    # Trim log if too long
    if [[ -f "$LOG_FILE" ]] && (( $(wc -l < "$LOG_FILE") > LOG_MAX_LINES )); then
        tail -n $((LOG_MAX_LINES / 2)) "$LOG_FILE" > "$LOG_FILE.tmp" && mv "$LOG_FILE.tmp" "$LOG_FILE"
    fi
}

empty_output() {
    echo '{"text":"","tooltip":"","class":"empty"}'
}

# ── CWD Detection ──────────────────────────────────────────────

get_cwd() {
    local win_info app_id term_pid
    win_info=$(niri msg --json focused-window 2>/dev/null)

    if [[ -n "$win_info" ]]; then
        app_id=$(echo "$win_info" | jq -r '.app_id // empty')
        term_pid=$(echo "$win_info" | jq -r '.pid // empty')

        # Only proceed for terminal emulators
        case "$app_id" in
            ghostty|foot|kitty|alacritty|wezterm|com.mitchellh.ghostty) ;;
            *) log "cwd: focused app '$app_id' is not a terminal, skipping"; return ;;
        esac
    fi

    # Check if a tmux client is a descendant of the focused terminal
    if command -v tmux &>/dev/null && tmux list-sessions &>/dev/null 2>&1; then
        if [[ -n "$term_pid" ]]; then
            while IFS=' ' read -r cpid sname; do
                local p="$cpid"
                while [[ -n "$p" && "$p" != "1" && "$p" != "0" ]]; do
                    if [[ "$p" == "$term_pid" ]]; then
                        local cwd
                        cwd=$(tmux display-message -t "$sname" -p '#{pane_current_path}' 2>/dev/null)
                        [[ -n "$cwd" ]] && echo "$cwd" && return
                        break
                    fi
                    p=$(awk '/^PPid:/{print $2}' "/proc/$p/status" 2>/dev/null)
                    [[ -z "$p" ]] && break
                done
            done < <(tmux list-clients -F '#{client_pid} #{session_name}' 2>/dev/null)
        else
            # No niri info available, fall back to any attached tmux session
            local cwd
            cwd=$(tmux list-panes -a -F '#{session_attached} #{window_active} #{pane_active} #{pane_current_path}' 2>/dev/null |
                  awk '$1=="1" && $2=="1" && $3=="1" {print $4; exit}')
            [[ -n "$cwd" ]] && echo "$cwd" && return
        fi
    fi

    # Bare terminal - find shell CWD via /proc
    if [[ -n "$term_pid" ]]; then
        local shell_pid
        shell_pid=$(pgrep -oP "$term_pid" 2>/dev/null)
        [[ -n "$shell_pid" ]] && readlink "/proc/$shell_pid/cwd" 2>/dev/null
    fi
}

# ── Git Remote Parsing ──────────────────────────────────────────

parse_devops_remote() {
    local url="$1"
    local org project repo
    # SSH: git@ssh.dev.azure.com:v3/{org}/{project}/{repo}
    if [[ "$url" =~ git@ssh\.dev\.azure\.com:v3/([^/]+)/([^/]+)/([^/[:space:]]+) ]]; then
        org="${BASH_REMATCH[1]}" project="${BASH_REMATCH[2]}" repo="${BASH_REMATCH[3]}"
    # HTTPS: https://{org}@dev.azure.com/{org}/{project}/_git/{repo}
    elif [[ "$url" =~ dev\.azure\.com/([^/]+)/([^/]+)/_git/([^/[:space:]]+) ]]; then
        org="${BASH_REMATCH[1]}" project="${BASH_REMATCH[2]}" repo="${BASH_REMATCH[3]}"
    else
        return 1
    fi
    echo "${org} ${project} ${repo%.git}"
}

# ── Azure DevOps Auth ──────────────────────────────────────────

PAT_STATUS_FILE="$CACHE_DIR/pat_status"
PAT_CHECK_TTL=300  # recheck expired PAT every 5 minutes

get_pat() {
    secret-tool lookup service azure-devops type waybar 2>/dev/null || return 1
}

pat_error_output() {
    local msg="$1" tooltip="$2"
    jq -cn --arg t "$msg" --arg tt "$tooltip" \
        '{text: $t, tooltip: $tt, class: "pat-error"}'
}

# Check if PAT is known to be invalid (cached from a previous 401).
# Returns 0 if OK to proceed, 1 if known invalid (prints waybar JSON).
check_pat_cache() {
    local pat="$1"
    local now pat_hash
    now=$(date +%s)
    pat_hash=$(echo -n "$pat" | md5sum | cut -d' ' -f1)

    if [[ -f "$PAT_STATUS_FILE" ]]; then
        local cached_at cached_hash
        read -r cached_at cached_hash < "$PAT_STATUS_FILE"
        if [[ "$cached_hash" == "$pat_hash" ]] && (( now - cached_at < PAT_CHECK_TTL )); then
            log "auth: PAT known invalid (age=$((now - cached_at))s), skipping API calls"
            pat_error_output "DevOps: PAT Expired" "PAT is expired or invalid\nUpdate: secret-tool store --label='Azure DevOps PAT (waybar)' service azure-devops type waybar"
            return 1
        fi
    fi
    return 0
}

# Call after any API curl that returned 401/403 to cache the failure.
mark_pat_invalid() {
    local pat="$1" http_code="$2"
    local now pat_hash
    now=$(date +%s)
    pat_hash=$(echo -n "$pat" | md5sum | cut -d' ' -f1)
    log "auth: PAT invalid (HTTP $http_code), caching failure for ${PAT_CHECK_TTL}s"
    echo "$now $pat_hash" > "$PAT_STATUS_FILE"
}

# ── Release Definition Discovery ────────────────────────────────

discover_environments() {
    local org="$1" project="$2" repo_name="$3" pat="$4"
    local cache_file="$CACHE_DIR/discovery_${org}_${project}_${repo_name}.json"
    local now
    now=$(date +%s)

    if [[ -f "$cache_file" ]]; then
        local cached_at
        cached_at=$(jq -r '.cached_at // 0' "$cache_file" 2>/dev/null)
        if (( now - cached_at < DISCOVERY_TTL )); then
            log "discovery: cache hit (age=$((now - cached_at))s)"
            cat "$cache_file"
            return
        fi
    fi

    log "discovery: resolving repo to build definitions..."
    local repo_guid
    repo_guid=$(get_repo_guid "$org" "$project" "$repo_name" "$pat") || return 1

    local build_defs http_code
    build_defs=$(curl -s -u ":$pat" -w '\n%{http_code}' \
        "https://dev.azure.com/$org/$project/_apis/build/definitions?repositoryId=$repo_guid&repositoryType=TfsGit&api-version=7.1")
    http_code=$(echo "$build_defs" | tail -1)
    build_defs=$(echo "$build_defs" | sed '$d')
    if [[ "$http_code" == "401" || "$http_code" == "403" ]]; then
        mark_pat_invalid "$pat" "$http_code"
        return 1
    fi
    [[ "$http_code" != 2* ]] && return 1

    local build_def_ids
    build_def_ids=$(echo "$build_defs" | jq '[.value[].id | tostring]' 2>/dev/null)
    log "discovery: build defs for repo: $build_def_ids"

    log "discovery: fetching release definitions..."
    local release_defs
    release_defs=$(curl -s -u ":$pat" -w '\n%{http_code}' \
        "https://vsrm.dev.azure.com/$org/$project/_apis/release/definitions?\$expand=artifacts,environments&api-version=7.1")
    http_code=$(echo "$release_defs" | tail -1)
    release_defs=$(echo "$release_defs" | sed '$d')
    if [[ "$http_code" == "401" || "$http_code" == "403" ]]; then
        mark_pat_invalid "$pat" "$http_code"
        return 1
    fi
    [[ "$http_code" != 2* ]] && return 1

    # Match release definitions whose artifact references a build definition
    # that targets this repo, then for each environment name, prefer the
    # definition where it's the final stage.
    local excluded="${EXCLUDE_DEFS[$repo_name]:-}"
    local exclude_json
    exclude_json=$(echo "$excluded" | jq -R 'split(" ") | map(select(. != "") | tonumber)' 2>/dev/null || echo "[]")
    log "discovery: excluding release defs: $exclude_json"

    local result
    result=$(echo "$release_defs" | jq --argjson bids "$build_def_ids" --argjson now "$now" --argjson excl "$exclude_json" '
        [.value[] |
         select(.id as $did | $excl | index($did) | not) |
         select(any(.artifacts[]?;
           .definitionReference.definition.id as $id | $bids | index($id))) |
         . as $def |
         (.environments | length) as $total |
         .environments | to_entries[] |
         {
           name: .value.name,
           def_id: $def.id,
           env_id: .value.id,
           is_final: (.key == ($total - 1))
         }
        ] |
        group_by(.name) |
        map(sort_by(if .is_final then 0 else 1 end, .def_id) | first |
            del(.is_final)) |
        sort_by(.name | ascii_downcase |
          if startswith("dev") then 0
          elif startswith("test") then 1
          elif startswith("stag") then 2
          elif startswith("prod") then 3
          else 4 end) |
        if length > 0 then {environments: ., cached_at: $now}
        else empty end
    ' 2>/dev/null)

    [[ -z "$result" ]] && return 1

    echo "$result" > "$cache_file"
    echo "$result"
}

# ── Query Deployments ────────────────────────────────────────────

get_deployments() {
    local org="$1" project="$2" pat="$3" env_info="$4"
    local repo_hash
    repo_hash=$(echo "$env_info" | jq -r '.environments | map(.env_id|tostring) | join("_")' 2>/dev/null)
    local cache_file="$CACHE_DIR/deploy_${org}_${project}_${repo_hash}.json"
    local now
    now=$(date +%s)

    if [[ -f "$cache_file" ]]; then
        local cached_at
        cached_at=$(jq -r '.cached_at // 0' "$cache_file" 2>/dev/null)
        if (( now - cached_at < DEPLOY_TTL )); then
            log "deployments: cache hit (age=$((now - cached_at))s)"
            cat "$cache_file"
            return
        fi
    fi

    log "deployments: fetching from API..."
    local result="[]"
    while IFS= read -r env; do
        local env_id env_name def_id
        env_id=$(echo "$env" | jq -r '.env_id')
        env_name=$(echo "$env" | jq -r '.name')
        def_id=$(echo "$env" | jq -r '.def_id')

        local deploy_data http_code branch
        deploy_data=$(curl -s -u ":$pat" -w '\n%{http_code}' \
            "https://vsrm.dev.azure.com/$org/$project/_apis/release/deployments?definitionId=$def_id&definitionEnvironmentId=$env_id&deploymentStatus=succeeded&\$top=1&api-version=7.1")
        http_code=$(echo "$deploy_data" | tail -1)
        deploy_data=$(echo "$deploy_data" | sed '$d')

        if [[ "$http_code" == "401" || "$http_code" == "403" ]]; then
            mark_pat_invalid "$pat" "$http_code"
            return 1
        fi

        branch=$(echo "$deploy_data" | jq -r '.value[0].release.artifacts[0].definitionReference.branch.name // empty' 2>/dev/null)

        # Strip refs/heads/ and common prefixes
        branch="${branch#refs/heads/}"
        branch="${branch#release/}"
        branch="${branch#feature/}"
        branch="${branch#bugfix/}"
        branch="${branch#hotfix/}"

        if [[ -n "$branch" ]]; then
            result=$(echo "$result" | jq --arg n "$env_name" --arg b "$branch" '. + [{name: $n, branch: $b}]')
        fi
    done < <(echo "$env_info" | jq -c '.environments[]')

    local output
    output=$(jq -n --argjson envs "$result" --argjson now "$now" '{environments: $envs, cached_at: $now}')
    echo "$output" > "$cache_file"
    echo "$output"
}

# ── Build Status ─────────────────────────────────────────────────

get_repo_guid() {
    local org="$1" project="$2" repo_name="$3" pat="$4"
    local cache_file="$CACHE_DIR/repoguid_${org}_${project}_${repo_name}.txt"
    local now
    now=$(date +%s)

    if [[ -f "$cache_file" ]]; then
        local cached_at guid
        read -r cached_at guid < "$cache_file"
        if (( now - cached_at < DISCOVERY_TTL )); then
            echo "$guid"
            return
        fi
    fi

    log "build: resolving repo GUID for $repo_name..."
    local repo_info http_code
    repo_info=$(curl -s -u ":$pat" -w '\n%{http_code}' \
        "https://dev.azure.com/$org/$project/_apis/git/repositories/$repo_name?api-version=7.1")
    http_code=$(echo "$repo_info" | tail -1)
    repo_info=$(echo "$repo_info" | sed '$d')
    log "build: repo lookup http=$http_code"
    if [[ "$http_code" == "401" || "$http_code" == "403" ]]; then
        mark_pat_invalid "$pat" "$http_code"
        return 1
    fi
    [[ "$http_code" != 2* ]] && { log "build: repo lookup error: $(echo "$repo_info" | head -c 200)"; return 1; }

    local guid
    guid=$(echo "$repo_info" | jq -r '.id // empty' 2>/dev/null)
    [[ -z "$guid" ]] && return 1

    echo "$now $guid" > "$cache_file"
    log "build: resolved repo GUID=$guid"
    echo "$guid"
}

get_active_build() {
    local org="$1" project="$2" repo_name="$3" pat="$4"
    local cache_file="$CACHE_DIR/build_${org}_${project}_${repo_name}.json"
    local now
    now=$(date +%s)

    if [[ -f "$cache_file" ]]; then
        local cached_at
        cached_at=$(jq -r '.cached_at // 0' "$cache_file" 2>/dev/null)
        if (( now - cached_at < BUILD_TTL )); then
            log "build: cache hit (age=$((now - cached_at))s)"
            cat "$cache_file"
            return
        fi
    fi

    local repo_guid
    repo_guid=$(get_repo_guid "$org" "$project" "$repo_name" "$pat") || return 1

    log "build: fetching from API..."
    local builds
    builds=$(curl -sf -u ":$pat" \
        "https://dev.azure.com/$org/$project/_apis/build/builds?repositoryId=$repo_guid&repositoryType=TfsGit&statusFilter=inProgress&\$top=1&api-version=7.1") || return 1

    local result
    result=$(echo "$builds" | jq --argjson now "$now" '
        if (.count // 0) > 0 then
            .value[0] | {
                id: .id,
                build_number: .buildNumber,
                start_time: .startTime,
                source_branch: (.sourceBranch // "" | sub("^refs/heads/"; "") | sub("^release/"; "") | sub("^feature/"; "") | sub("^bugfix/"; "") | sub("^hotfix/"; "")),
                cached_at: $now
            }
        else
            {active: false, cached_at: $now}
        end
    ' 2>/dev/null)

    [[ -z "$result" ]] && return 1
    echo "$result" > "$cache_file"
    echo "$result"
}

get_build_progress() {
    local org="$1" project="$2" build_id="$3" pat="$4"
    local cache_file="$CACHE_DIR/timeline_${org}_${project}_${build_id}.json"
    local now
    now=$(date +%s)

    if [[ -f "$cache_file" ]]; then
        local cached_at
        cached_at=$(jq -r '.cached_at // 0' "$cache_file" 2>/dev/null)
        if (( now - cached_at < BUILD_TTL )); then
            log "timeline: cache hit (age=$((now - cached_at))s)"
            cat "$cache_file"
            return
        fi
    fi

    log "timeline: fetching from API..."
    local timeline
    timeline=$(curl -sf -u ":$pat" \
        "https://dev.azure.com/$org/$project/_apis/build/builds/$build_id/timeline?api-version=7.1") || return 1

    # Extract stage info as JSON (elapsed time computed fresh in main)
    local result
    result=$(echo "$timeline" | jq --argjson now "$now" '
        [.records[] | select(.type == "Stage") | {
            name: .name,
            state: .state,
            result: (.result // ""),
            order: .order
        }] | sort_by(.order) |
        . as $stages |
        ($stages | length) as $total |
        ([.[] | select(.state == "completed")] | length) as $completed |
        ([.[] | select(.state == "inProgress")][0].name // "...") as $current |
        {
            stage_progress: "\($completed + 1)/\($total)",
            current_stage: $current,
            tooltip_stages: ([.[] |
                (if .state == "completed" then
                    (if .result == "succeeded" then "✓" else "✗" end)
                elif .state == "inProgress" then "→"
                else "·" end) + " " + .name
            ] | join("\\n")),
            cached_at: $now
        }
    ' 2>/dev/null)

    [[ -z "$result" ]] && return 1
    echo "$result" > "$cache_file"
    echo "$result"
}

# ── Elapsed Time Formatting ──────────────────────────────────────

format_elapsed() {
    local start_time="$1"
    local start_epoch elapsed
    start_epoch=$(date -d "$start_time" +%s 2>/dev/null)
    elapsed=$(( $(date +%s) - start_epoch ))
    if (( elapsed / 60 > 0 )); then
        echo "$((elapsed / 60))m $((elapsed % 60))s"
    else
        echo "$((elapsed % 60))s"
    fi
}

# ── Release Branch Merge Check ──────────────────────────────────

do_git_fetch() {
    local git_root="$1"
    local cache_key
    cache_key=$(echo -n "$git_root" | md5sum | cut -d' ' -f1)
    local fetch_ts_file="$CACHE_DIR/fetch_${cache_key}.txt"
    local now
    now=$(date +%s)

    if [[ -f "$fetch_ts_file" ]]; then
        local cached_at
        read -r cached_at < "$fetch_ts_file"
        if (( now - cached_at < MERGE_CHECK_TTL )); then
            return
        fi
    fi

    log "fetch: refreshing remote refs"
    timeout 10 git -C "$git_root" fetch origin --quiet 2>/dev/null
    echo "$now" > "$fetch_ts_file"
}

check_release_merged() {
    local git_root="$1" branch="$2"
    local release_branch="release/$branch"

    do_git_fetch "$git_root"

    if ! git -C "$git_root" rev-parse "origin/$release_branch" &>/dev/null; then
        log "merge-check: origin/$release_branch not found"
        echo "unknown"
        return
    fi

    if git -C "$git_root" merge-base --is-ancestor "origin/$release_branch" origin/main 2>/dev/null; then
        log "merge-check: $release_branch merged"
        echo "merged"
    else
        log "merge-check: $release_branch NOT merged"
        echo "unmerged"
    fi
}

# ── State Management ─────────────────────────────────────────────

save_state() {
    jq -n --arg text "$1" --arg tooltip "$2" --argjson t "$(date +%s)" \
        '{text: $text, tooltip: $tooltip, last_seen: $t}' > "$STATE_FILE"
}

check_stale_state() {
    [[ -f "$STATE_FILE" ]] || return 1
    local last_seen text
    last_seen=$(jq -r '.last_seen // 0' "$STATE_FILE" 2>/dev/null)
    text=$(jq -r '.text // empty' "$STATE_FILE" 2>/dev/null)
    [[ -z "$text" ]] && return 1
    (( $(date +%s) - last_seen >= STALE_TIMEOUT )) && return 1
    cat "$STATE_FILE"
}

# ── Build Lifecycle State Machine ────────────────────────────────

load_lifecycle() {
    [[ -f "$LIFECYCLE_FILE" ]] || return 1
    local state
    state=$(jq -r '.state // "idle"' "$LIFECYCLE_FILE" 2>/dev/null)
    [[ "$state" == "idle" ]] && return 1
    cat "$LIFECYCLE_FILE"
}

save_lifecycle() {
    echo "$1" > "$LIFECYCLE_FILE"
}

clear_lifecycle() {
    jq -n '{state: "idle"}' > "$LIFECYCLE_FILE"
}

# Query a single build by ID
query_build_by_id() {
    local org="$1" project="$2" build_id="$3" pat="$4"
    curl -sf -u ":$pat" \
        "https://dev.azure.com/$org/$project/_apis/build/builds/$build_id?api-version=7.1"
}

# Query release deployments by status
query_release_deployments() {
    local org="$1" project="$2" pat="$3" status="$4"
    curl -sf -u ":$pat" \
        "https://vsrm.dev.azure.com/$org/$project/_apis/release/deployments?deploymentStatus=$status&\$top=10&api-version=7.1"
}

# Start tracking a new build in the lifecycle
start_lifecycle_build() {
    local org="$1" project="$2" repo_name="$3"
    local build_id="$4" build_number="$5" source_branch="$6" started_at="$7" repo_dir="$8"
    log "lifecycle: tracking build $build_id"
    save_lifecycle "$(jq -n \
        --arg org "$org" \
        --arg project "$project" \
        --arg repo "$repo_name" \
        --arg bid "$build_id" \
        --arg bnum "$build_number" \
        --arg branch "$source_branch" \
        --arg started "$started_at" \
        --arg rd "$repo_dir" \
        '{state: "building", org: $org, project: $project, repo_name: $repo,
          build_id: $bid, build_number: $bnum,
          source_branch: $branch, started_at: $started, repo_dir: $rd}')"
}

# Handle the lifecycle state machine. Returns 0 and prints waybar JSON if
# there's an active lifecycle state, or returns 1 to fall through.
handle_lifecycle() {
    local lc
    lc=$(load_lifecycle) || return 1

    local state org project build_id started_at build_number source_branch repo_dir
    state=$(echo "$lc" | jq -r '.state')
    org=$(echo "$lc" | jq -r '.org')
    project=$(echo "$lc" | jq -r '.project')
    build_id=$(echo "$lc" | jq -r '.build_id')
    started_at=$(echo "$lc" | jq -r '.started_at')
    build_number=$(echo "$lc" | jq -r '.build_number')
    source_branch=$(echo "$lc" | jq -r '.source_branch')
    repo_dir=$(echo "$lc" | jq -r '.repo_dir // "build"')

    local pat
    if ! pat=$(get_pat); then
        log "lifecycle: no PAT"
        pat_error_output "DevOps: No PAT" "No PAT configured\nAdd: secret-tool store --label='Azure DevOps PAT (waybar)' service azure-devops type waybar"
        return 0
    fi

    if ! check_pat_cache "$pat"; then
        return 0
    fi

    local now
    now=$(date +%s)

    case "$state" in
        building)
            log "lifecycle: checking build $build_id"
            local build_data
            build_data=$(query_build_by_id "$org" "$project" "$build_id" "$pat")
            if [[ -z "$build_data" ]]; then
                log "lifecycle: failed to query build, clearing"
                clear_lifecycle
                return 1
            fi

            local build_status build_result
            build_status=$(echo "$build_data" | jq -r '.status // "unknown"')
            build_result=$(echo "$build_data" | jq -r '.result // "none"')
            log "lifecycle: status=$build_status result=$build_result"

            if [[ "$build_status" == "completed" ]]; then
                local elapsed_fmt
                elapsed_fmt=$(format_elapsed "$started_at")

                if [[ "$build_result" == "succeeded" ]]; then
                    log "lifecycle: build succeeded"
                    save_lifecycle "$(echo "$lc" | jq --argjson now "$now" --arg be "$elapsed_fmt" \
                        '.state = "build_succeeded" | .result = "succeeded" | .completed_at = $now | .build_elapsed = $be')"
                    local text="${repo_dir}: ✓ Build Succeeded - ${elapsed_fmt}"
                    local tooltip="Build #${build_number} - ${source_branch}\nSucceeded"
                    save_state "$text" "$tooltip"
                    jq -cn --arg t "$text" --arg tt "$tooltip" \
                        '{text: $t, tooltip: $tt, class: "build-succeeded"}'
                    return 0
                else
                    # Get the failed stage name from timeline
                    local failed_stage="Unknown"
                    local timeline
                    timeline=$(curl -sf -u ":$pat" \
                        "https://dev.azure.com/$org/$project/_apis/build/builds/$build_id/timeline?api-version=7.1")
                    if [[ -n "$timeline" ]]; then
                        failed_stage=$(echo "$timeline" | jq -r '
                            [.records[] | select(.type == "Stage" and .result != null and .result != "succeeded")] |
                            first | .name // "Unknown"')
                    fi
                    log "lifecycle: build failed at $failed_stage"
                    save_lifecycle "$(echo "$lc" | jq --argjson now "$now" --arg fs "$failed_stage" --arg be "$elapsed_fmt" \
                        '.state = "build_failed" | .result = "failed" | .completed_at = $now | .failed_stage = $fs | .build_elapsed = $be')"
                    local text="${repo_dir}: ✗ Build Failed (${failed_stage}) - ${elapsed_fmt}"
                    local tooltip="Build #${build_number} - ${source_branch}\nFailed at: ${failed_stage}"
                    save_state "$text" "$tooltip"
                    jq -cn --arg t "$text" --arg tt "$tooltip" \
                        '{text: $t, tooltip: $tt, class: "build-failed"}'
                    return 0
                fi
            fi

            # Still building - show progress
            local progress
            progress=$(get_build_progress "$org" "$project" "$build_id" "$pat")
            if [[ -n "$progress" ]]; then
                local stage_progress current_stage elapsed_fmt tooltip_stages
                stage_progress=$(echo "$progress" | jq -r '.stage_progress')
                current_stage=$(echo "$progress" | jq -r '.current_stage')
                elapsed_fmt=$(format_elapsed "$started_at")
                tooltip_stages=$(echo "$progress" | jq -r '.tooltip_stages')

                local text="${repo_dir}: Building (${stage_progress}: ${current_stage}) - ${elapsed_fmt}"
                local tooltip="Build #${build_number} - ${source_branch}\n${tooltip_stages}"
                log "lifecycle: $text"
                save_state "$text" "$tooltip"
                jq -cn --arg t "$text" --arg tt "$tooltip" \
                    '{text: $t, tooltip: $tt, class: "building"}'
                return 0
            fi

            # Fallback: generic building message
            local elapsed_fmt
            elapsed_fmt=$(format_elapsed "$started_at")
            local text="${repo_dir}: Building - ${elapsed_fmt}"
            save_state "$text" ""
            jq -cn --arg t "$text" '{text: $t, tooltip: "", class: "building"}'
            return 0
            ;;

        build_failed)
            local completed_at
            completed_at=$(echo "$lc" | jq -r '.completed_at // 0')
            if (( now - completed_at >= PERSIST_TIMEOUT )); then
                log "lifecycle: build_failed expired"
                clear_lifecycle
                return 1
            fi
            local failed_stage build_elapsed
            failed_stage=$(echo "$lc" | jq -r '.failed_stage // "Unknown"')
            build_elapsed=$(echo "$lc" | jq -r '.build_elapsed // "?"')
            local text="${repo_dir}: ✗ Build Failed (${failed_stage}) - ${build_elapsed}"
            local tooltip="Build #${build_number} - ${source_branch}\nFailed at: ${failed_stage}"
            save_state "$text" "$tooltip"
            jq -cn --arg t "$text" --arg tt "$tooltip" \
                '{text: $t, tooltip: $tt, class: "build-failed"}'
            return 0
            ;;

        build_succeeded)
            local completed_at
            completed_at=$(echo "$lc" | jq -r '.completed_at // 0')
            if (( now - completed_at >= PERSIST_TIMEOUT )); then
                log "lifecycle: build_succeeded expired, no release found"
                clear_lifecycle
                return 1
            fi

            # Poll for a release triggered by this build
            log "lifecycle: polling for release"
            local deployments
            deployments=$(query_release_deployments "$org" "$project" "$pat" "inProgress")
            if [[ -n "$deployments" ]]; then
                local match
                match=$(echo "$deployments" | jq --arg bid "$build_id" '
                    [.value[]? | select(
                        any(.release.artifacts[]?;
                            .definitionReference.version.id == $bid)
                    )] | first // empty')

                if [[ -n "$match" && "$match" != "null" ]]; then
                    local release_id release_env
                    release_id=$(echo "$match" | jq -r '.release.id')
                    release_env=$(echo "$match" | jq -r '.releaseEnvironment.name // "Unknown"')
                    log "lifecycle: found release $release_id to $release_env"
                    save_lifecycle "$(echo "$lc" | jq \
                        --arg rid "$release_id" --arg env "$release_env" --argjson rs "$now" \
                        '.state = "releasing" | .release_id = $rid | .release_env = $env | .release_started_at = $rs')"
                    local text="${repo_dir}: Releasing ${source_branch} to ${release_env}"
                    local tooltip="Build #${build_number} - ${source_branch}\nReleasing to ${release_env}"
                    save_state "$text" "$tooltip"
                    jq -cn --arg t "$text" --arg tt "$tooltip" \
                        '{text: $t, tooltip: $tt, class: "releasing"}'
                    return 0
                fi
            fi

            # No release found yet, keep showing build succeeded
            local build_elapsed
            build_elapsed=$(echo "$lc" | jq -r '.build_elapsed // "?"')
            local text="${repo_dir}: ✓ Build Succeeded - ${build_elapsed}"
            local tooltip="Build #${build_number} - ${source_branch}\nSucceeded"
            save_state "$text" "$tooltip"
            jq -cn --arg t "$text" --arg tt "$tooltip" \
                '{text: $t, tooltip: $tt, class: "build-succeeded"}'
            return 0
            ;;

        releasing)
            local release_id release_env
            release_id=$(echo "$lc" | jq -r '.release_id')
            release_env=$(echo "$lc" | jq -r '.release_env')
            log "lifecycle: checking release $release_id env=$release_env"

            local deployments still_active="false"
            deployments=$(query_release_deployments "$org" "$project" "$pat" "inProgress")
            if [[ -n "$deployments" ]]; then
                still_active=$(echo "$deployments" | jq --arg rid "$release_id" \
                    '[.value[]? | select(.release.id == ($rid | tonumber))] | length > 0')
            fi

            if [[ "$still_active" == "true" ]]; then
                local release_started_at release_elapsed release_min release_sec elapsed_fmt
                release_started_at=$(echo "$lc" | jq -r '.release_started_at // 0')
                release_elapsed=$(( now - release_started_at ))
                release_min=$((release_elapsed / 60))
                release_sec=$((release_elapsed % 60))
                if (( release_min > 0 )); then
                    elapsed_fmt="${release_min}m ${release_sec}s"
                else
                    elapsed_fmt="${release_sec}s"
                fi
                local text="${repo_dir}: Releasing ${source_branch} to ${release_env} - ${elapsed_fmt}"
                local tooltip="Build #${build_number} - ${source_branch}\nReleasing to ${release_env}"
                save_state "$text" "$tooltip"
                jq -cn --arg t "$text" --arg tt "$tooltip" \
                    '{text: $t, tooltip: $tt, class: "releasing"}'
                return 0
            fi

            # Release finished - check result
            log "lifecycle: release finished, checking result"
            local succeeded_deps release_succeeded="false"
            succeeded_deps=$(query_release_deployments "$org" "$project" "$pat" "succeeded")
            if [[ -n "$succeeded_deps" ]]; then
                release_succeeded=$(echo "$succeeded_deps" | jq \
                    --arg rid "$release_id" --arg env "$release_env" '
                    [.value[]? | select(
                        .release.id == ($rid | tonumber) and
                        .releaseEnvironment.name == $env
                    )] | length > 0')
            fi

            local release_started_at release_elapsed release_min release_sec release_elapsed_fmt
            release_started_at=$(echo "$lc" | jq -r '.release_started_at // 0')
            release_elapsed=$(( now - release_started_at ))
            release_min=$((release_elapsed / 60))
            release_sec=$((release_elapsed % 60))
            if (( release_min > 0 )); then
                release_elapsed_fmt="${release_min}m ${release_sec}s"
            else
                release_elapsed_fmt="${release_sec}s"
            fi

            local release_result text
            if [[ "$release_succeeded" == "true" ]]; then
                release_result="succeeded"
                text="${repo_dir}: ✓ Released ${source_branch} to ${release_env} - ${release_elapsed_fmt}"
            else
                release_result="failed"
                text="${repo_dir}: ✗ Release Failed (${release_env}) - ${release_elapsed_fmt}"
            fi
            local tooltip="Build #${build_number} - ${source_branch}\nRelease to ${release_env}: ${release_result}"
            log "lifecycle: release $release_result"
            save_lifecycle "$(echo "$lc" | jq --argjson now "$now" --arg rr "$release_result" --arg re "$release_elapsed_fmt" \
                '.state = "release_done" | .release_completed_at = $now | .release_result = $rr | .release_elapsed = $re')"
            save_state "$text" "$tooltip"
            jq -cn --arg t "$text" --arg tt "$tooltip" \
                '{text: $t, tooltip: $tt, class: "release-done"}'
            return 0
            ;;

        release_done)
            local release_completed_at
            release_completed_at=$(echo "$lc" | jq -r '.release_completed_at // 0')
            if (( now - release_completed_at >= PERSIST_TIMEOUT )); then
                log "lifecycle: release_done expired"
                clear_lifecycle
                return 1
            fi
            local release_env release_result
            release_env=$(echo "$lc" | jq -r '.release_env')
            release_result=$(echo "$lc" | jq -r '.release_result // "unknown"')

            local release_elapsed text tooltip
            release_elapsed=$(echo "$lc" | jq -r '.release_elapsed // "?"')
            if [[ "$release_result" == "succeeded" ]]; then
                text="${repo_dir}: ✓ Released ${source_branch} to ${release_env} - ${release_elapsed}"
            else
                text="${repo_dir}: ✗ Release Failed (${release_env}) - ${release_elapsed}"
            fi
            tooltip="Build #${build_number} - ${source_branch}\nRelease to ${release_env}: ${release_result}"
            save_state "$text" "$tooltip"
            jq -cn --arg t "$text" --arg tt "$tooltip" \
                '{text: $t, tooltip: $tt, class: "release-done"}'
            return 0
            ;;

        *)
            log "lifecycle: unknown state '$state', clearing"
            clear_lifecycle
            return 1
            ;;
    esac
}

# ── Main ─────────────────────────────────────────────────────────

main() {
    # Check lifecycle state first - persists regardless of focused window
    if handle_lifecycle; then
        return
    fi

    local cwd
    cwd=$(get_cwd)
    log "cwd: $cwd"

    local git_root=""
    if [[ -n "$cwd" ]]; then
        git_root=$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null)
    fi

    if [[ -z "$git_root" ]]; then
        local stale
        if stale=$(check_stale_state); then
            log "not in git repo, showing stale state"
            echo "$stale" | jq -c '{text: .text, tooltip: .tooltip, class: "stale"}'
        else
            log "not in git repo, empty"
            empty_output
        fi
        return
    fi

    local remote_url
    remote_url=$(git -C "$git_root" remote get-url origin 2>/dev/null)
    local parsed
    if ! parsed=$(parse_devops_remote "$remote_url"); then
        log "remote '$remote_url' is not Azure DevOps"
        empty_output
        return
    fi

    local org project repo_name
    read -r org project repo_name <<< "$parsed"
    log "devops: org=$org project=$project repo=$repo_name"

    local pat
    if ! pat=$(get_pat); then
        log "ERROR: no PAT in keyring"
        pat_error_output "DevOps: No PAT" "No PAT configured\nAdd: secret-tool store --label='Azure DevOps PAT (waybar)' service azure-devops type waybar"
        return
    fi

    if ! check_pat_cache "$pat"; then
        return
    fi
    log "auth: ok"

    # Check for active builds first (takes precedence over deployments)
    local build_info
    if build_info=$(get_active_build "$org" "$project" "$repo_name" "$pat"); then
        local has_build
        has_build=$(echo "$build_info" | jq -r '.id // empty')
        if [[ -n "$has_build" ]]; then
            local build_id start_time build_number source_branch
            build_id=$(echo "$build_info" | jq -r '.id')
            start_time=$(echo "$build_info" | jq -r '.start_time')
            build_number=$(echo "$build_info" | jq -r '.build_number')
            source_branch=$(echo "$build_info" | jq -r '.source_branch')

            # Start lifecycle tracking for this build
            local repo_dir
            repo_dir=$(basename "$git_root")
            start_lifecycle_build "$org" "$project" "$repo_name" \
                "$build_id" "$build_number" "$source_branch" "$start_time" "$repo_dir"

            local progress
            progress=$(get_build_progress "$org" "$project" "$build_id" "$pat")

            if [[ -n "$progress" ]]; then
                local stage_progress current_stage elapsed_fmt tooltip_stages
                stage_progress=$(echo "$progress" | jq -r '.stage_progress')
                current_stage=$(echo "$progress" | jq -r '.current_stage')
                elapsed_fmt=$(format_elapsed "$start_time")
                tooltip_stages=$(echo "$progress" | jq -r '.tooltip_stages')

                local text="${repo_dir}: Building (${stage_progress}: ${current_stage}) - ${elapsed_fmt}"
                local tooltip="Build #${build_number} - ${source_branch}\n${tooltip_stages}"

                log "output (build): $text"
                save_state "$text" "$tooltip"
                jq -cn --arg text "$text" --arg tooltip "$tooltip" '{text: $text, tooltip: $tooltip, class: "building"}'
                return
            fi
        fi
    fi

    # If an API call above marked the PAT invalid, stop and show error
    if [[ -f "$PAT_STATUS_FILE" ]] && ! check_pat_cache "$pat"; then
        return
    fi

    local env_info
    if ! env_info=$(discover_environments "$org" "$project" "$repo_name" "$pat"); then
        # Check again - discover may have detected expired PAT
        if [[ -f "$PAT_STATUS_FILE" ]] && ! check_pat_cache "$pat"; then
            return
        fi
        log "no release definition found for $repo_name"
        empty_output
        return
    fi
    log "environments: $(echo "$env_info" | jq -c '[.environments[] | .name]')"

    local deployments
    deployments=$(get_deployments "$org" "$project" "$pat" "$env_info")

    local text="" tooltip=""
    while IFS= read -r env; do
        local name branch
        name=$(echo "$env" | jq -r '.name')
        branch=$(echo "$env" | jq -r '.branch')

        local initial="${name:0:1}"
        [[ -n "$text" ]] && text+="    "
        text+="${initial}: ${branch}"

        [[ -n "$tooltip" ]] && tooltip+="\n"
        tooltip+="${name}: ${branch}"
    done < <(echo "$deployments" | jq -c '.environments[]' 2>/dev/null)

    if [[ -z "$text" ]]; then
        log "no deployment data found"
        empty_output
        return
    fi

    # Check merge status of deployed release branches
    local checked="" unmerged_branches=""
    while IFS= read -r env; do
        local branch
        branch=$(echo "$env" | jq -r '.branch')
        [[ " $checked " == *" $branch "* ]] && continue
        checked+=" $branch"
        if [[ "$branch" =~ ^[0-9]+\.[0-9]+ ]]; then
            local merge_status
            merge_status=$(check_release_merged "$git_root" "$branch")
            if [[ "$merge_status" == "unmerged" ]]; then
                [[ -n "$unmerged_branches" ]] && unmerged_branches+=", "
                unmerged_branches+="$branch"
            fi
        fi
    done < <(echo "$deployments" | jq -c '.environments[]' 2>/dev/null)

    if [[ -n "$unmerged_branches" ]]; then
        text+="  <span color='#fab387'>⚠</span>"
        tooltip+="\n\n⚠ Not merged to main: ${unmerged_branches}"
    fi

    log "output: $text"
    save_state "$text" "$tooltip"
    jq -cn --arg text "$text" --arg tooltip "$tooltip" \
        '{text: $text, tooltip: $tooltip, class: "active"}'
}

main
