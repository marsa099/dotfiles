#!/usr/bin/env bash
# Waybar audio-output module + actions.
#
#   waybar-audio-output           -> JSON status (used by waybar exec)
#   waybar-audio-output toggle    -> swap default sink between Speaker/AirPods
#   waybar-audio-output mute      -> toggle mute on default sink
#
# Icons (Nerd Font / Material Design):
#   󰟅 earbuds         -> AirPods active
#   󰓃 volume-high     -> Laptop speaker active
# When muted, the same glyph is rendered with pango strikethrough.
set -euo pipefail

ICON_AIRPODS="󰥰"
ICON_SPEAKER="󰢩"
SPEAKER_PATTERN='Speaker'
BLUEZ_PATTERN='AirPods'
WAYBAR_SIGNAL=11
BLUEZ_DEVICE_ID_FILE="/tmp/.waybar-audio-bluez-id"

find_sink() {
    wpctl status | awk -v pat="$1" '
        /^ ├─ Sinks:/ { in_sinks = 1; next }
        /^ ├─/ || /^ └─/ { in_sinks = 0 }
        in_sinks && $0 ~ pat {
            for (i=1; i<=NF; i++) if ($i ~ /^[0-9]+\.$/) { sub(/\./, "", $i); print $i; exit }
        }'
}

current_default_id() {
    wpctl status | awk '
        /^ ├─ Sinks:/ { in_sinks = 1; next }
        /^ ├─/ || /^ └─/ { in_sinks = 0 }
        in_sinks && /\*/ {
            for (i=1; i<=NF; i++) if ($i ~ /^[0-9]+\.$/) { sub(/\./, "", $i); print $i; exit }
        }'
}

is_muted() {
    wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | grep -q '\[MUTED\]'
}

current_volume_pct() {
    wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null \
        | awk '{ printf "%d", $2 * 100 }'
}

refresh_waybar() {
    pkill -RTMIN+$WAYBAR_SIGNAL waybar 2>/dev/null || true
}

action_toggle() {
    local speaker_id bluez_id current
    speaker_id="$(find_sink "$SPEAKER_PATTERN" || true)"
    bluez_id="$(find_sink "$BLUEZ_PATTERN" || true)"
    current="$(current_default_id || true)"

    if [[ -z "$speaker_id" ]]; then
        return 1
    fi

    if [[ -z "$bluez_id" || "$current" == "$bluez_id" ]]; then
        wpctl set-default "$speaker_id"
    else
        wpctl set-default "$bluez_id"
    fi
    refresh_waybar
}

action_mute() {
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
    refresh_waybar
}

bluez_device_id() {
    wpctl status | awk '
        /^ ├─ Devices:/ { in_dev = 1; next }
        /^ ├─/ || /^ └─/ { in_dev = 0 }
        in_dev && /\[bluez5\]/ {
            for (i=1; i<=NF; i++) if ($i ~ /^[0-9]+\.$/) { sub(/\./, "", $i); print $i; exit }
        }'
}

action_set_profile() {
    local profile="$1" id
    id="$(bluez_device_id || true)"
    if [[ -z "$id" ]]; then
        notify-send -a "Audio" "AirPods not connected" "Cannot set profile $profile" 2>/dev/null || true
        return 1
    fi
    wpctl set-profile "$id" "$profile"
    refresh_waybar
}

action_menu() {
    local default_id desc bluez_id is_bluez muted_label src_label entries chosen
    default_id="$(current_default_id || true)"
    desc="$(wpctl inspect "$default_id" 2>/dev/null | awk -F'"' '/node\.description/ { print $2; exit }')"
    bluez_id="$(find_sink "$BLUEZ_PATTERN" || true)"

    if [[ "$desc" == *"$BLUEZ_PATTERN"* ]]; then
        is_bluez=1
        src_label="󰢩  Switch to Laptop Speakers"
    else
        is_bluez=0
        if [[ -n "$bluez_id" ]]; then
            src_label="󰥰  Switch to AirPods"
        else
            src_label="󰥎  AirPods not connected"
        fi
    fi

    if is_muted; then
        muted_label="󰕾  Unmute"
    else
        muted_label="󰝟  Mute"
    fi

    entries="$src_label
$muted_label
󰕾  Volume +5%
󰖀  Volume -5%
󰍝  Open mixer (pavucontrol)"

    if [[ -n "$bluez_id" || $is_bluez -eq 1 ]]; then
        entries="$entries
󰗅  AirPods profile: A2DP (high-quality stereo)
󰗅  AirPods profile: HFP-mSBC (mic, wideband)
󰗅  AirPods profile: HFP-CVSD (mic, narrowband)
󰂲  Disconnect AirPods"
    fi

    chosen="$(printf '%s\n' "$entries" | fuzzel --dmenu --prompt 'audio › ' --lines 12 --width 36 || true)"
    [[ -z "$chosen" ]] && return 0

    case "$chosen" in
        *"Switch to Laptop Speakers"|*"Switch to AirPods") action_toggle ;;
        *"Mute"|*"Unmute") action_mute ;;
        *"Volume +5%") wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ ;;
        *"Volume -5%") wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- ;;
        *"Open mixer"*) setsid pavucontrol >/dev/null 2>&1 & ;;
        *"A2DP"*) action_set_profile "a2dp-sink" ;;
        *"HFP-mSBC"*) action_set_profile "headset-head-unit-msbc" ;;
        *"HFP-CVSD"*) action_set_profile "headset-head-unit-cvsd" ;;
        *"Disconnect AirPods")
            local addr
            addr="$(wpctl inspect "$(bluez_device_id)" 2>/dev/null | awk -F'"' '/api\.bluez5\.address/ { print $2; exit }')"
            [[ -n "$addr" ]] && bluetoothctl disconnect "$addr" >/dev/null 2>&1 || true
            ;;
    esac
    refresh_waybar
}

emit_status() {
    local default_id desc icon kind class glyph muted vol tooltip
    default_id="$(current_default_id || true)"
    if [[ -z "$default_id" ]]; then
        printf '{"text":"","class":"none","tooltip":"no audio sink"}\n'
        return
    fi

    desc="$(wpctl inspect "$default_id" 2>/dev/null | awk -F'"' '/node\.description/ { print $2; exit }')"

    if [[ "$desc" == *"$BLUEZ_PATTERN"* ]]; then
        icon="$ICON_AIRPODS"
        kind="airpods"
    else
        icon="$ICON_SPEAKER"
        kind="speaker"
    fi

    if is_muted; then
        glyph="<span strikethrough='true' strikethrough_color='#FF7B72'>${icon}</span>"
        class="${kind} muted"
        muted=" (muted)"
    else
        glyph="$icon"
        class="$kind"
        muted=""
    fi

    vol="$(current_volume_pct)"
    tooltip="${desc}${muted} — ${vol}%\\nLeft click: switch source\\nRight click: menu\\nScroll: volume"

    printf '{"text":"%s","class":"%s","tooltip":"%s"}\n' "$glyph" "$class" "$tooltip"
}

case "${1:-status}" in
    status) emit_status ;;
    toggle) action_toggle; emit_status ;;
    mute)   action_mute;   emit_status ;;
    menu)   action_menu ;;
    *) echo "usage: $0 {status|toggle|mute|menu}" >&2; exit 2 ;;
esac
